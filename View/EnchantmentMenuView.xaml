<UserControl x:Class="SkyrimCraftingTool.View.EnchantmentMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SkyrimCraftingTool.ViewModel"
             xmlns:model="clr-namespace:SkyrimCraftingTool.Model">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: TREEVIEW -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="5" Margin="0,0,10,0">
            <TreeView ItemsSource="{Binding TreeItems}"
                      SelectedItemChanged="TreeView_SelectedItemChanged">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="Black"/>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>

        <!-- RIGHT: DETAIL VIEW -->
        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel DataContext="{Binding SelectedEnchantment}">

                    <!-- TITLE -->
                    <TextBlock Text="{Binding Name}"
                               FontSize="22"
                               Foreground="LightSkyBlue"
                               Margin="0,0,0,10"/>

                    <!-- BASIC INFO -->
                    <StackPanel Orientation="Vertical" Margin="0,0,0,20">
                        <TextBlock Text="Basic Info"
                                   FontSize="16"
                                   Foreground="LightGray"
                                   Margin="0,0,0,5"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Key:" Width="120" Foreground="Gray"/>
                            <TextBlock Text="{Binding Key}" Foreground="White"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Cast Type:" Width="120" Foreground="Gray"/>
                            <TextBlock Text="{Binding CastType}" Foreground="White"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Target Type:" Width="120" Foreground="Gray"/>
                            <TextBlock Text="{Binding TargetType}" Foreground="White"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Cost:" Width="120" Foreground="Gray"/>
                            <TextBlock Text="{Binding EnchantmentCost}" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- EFFECTS -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Effects"
                                   FontSize="16"
                                   Foreground="LightGray"
                                   Margin="0,0,0,5"/>

                        <ItemsControl ItemsSource="{Binding Effects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Gray" BorderThickness="1" Padding="5" Margin="0,0,0,5">
                                        <StackPanel>

                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Magic Effect:" Width="120" Foreground="Gray"/>
                                                <TextBlock Text="{Binding MagicEffectKey}" Foreground="White"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Magnitude:" Width="120" Foreground="Gray"/>
                                                <TextBlock Text="{Binding Magnitude}" Foreground="White"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Duration:" Width="120" Foreground="Gray"/>
                                                <TextBlock Text="{Binding Duration}" Foreground="White"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Area:" Width="120" Foreground="Gray"/>
                                                <TextBlock Text="{Binding Area}" Foreground="White"/>
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- WORN RESTRICTIONS -->
                    <StackPanel>
                        <TextBlock Text="Worn Restrictions"
                                   FontSize="16"
                                   Foreground="LightGray"
                                   Margin="0,0,0,5"/>

                        <ItemsControl ItemsSource="{Binding WornRestrictionKeywords}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="White"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>
