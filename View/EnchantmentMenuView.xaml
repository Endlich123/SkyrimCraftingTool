<UserControl x:Class="SkyrimCraftingTool.View.EnchantmentMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SkyrimCraftingTool.ViewModel"
             xmlns:model="clr-namespace:SkyrimCraftingTool.Model">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: TREEVIEW -->
        <Border BorderBrush="Gray" BorderThickness="1" Padding="5" Margin="0,0,10,0">
            <TreeView ItemsSource="{Binding TreeItems}"
                      SelectedItemChanged="TreeView_SelectedItemChanged">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding DisplayName}"
                                   Foreground="Black"/>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>

        <!-- RIGHT: DETAIL VIEW -->
        <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel DataContext="{Binding SelectedEnchantment}">

                    <!-- TITLE -->
                    <TextBlock Text="{Binding Name}"
                               FontSize="22"
                               Foreground="LightSkyBlue"
                               Margin="0,0,0,10"/>

                    <!-- BASIC INFO -->
                    <StackPanel Orientation="Vertical" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <!-- Header -->
                                <RowDefinition Height="Auto" />
                                <!-- Key -->
                                <RowDefinition Height="Auto" />
                                <!-- EditorID -->
                                <RowDefinition Height="Auto" />
                                <!-- Name -->
                                <RowDefinition Height="Auto" />
                                <!-- CastType -->
                                <RowDefinition Height="Auto" />
                                <!-- TargetType -->
                                <RowDefinition Height="Auto" />
                                <!-- EnchantmentCost -->
                            </Grid.RowDefinitions>
                            
                            <!-- Header -->
                            <TextBlock Grid.Row="0"
                               Text="Basic Info"
                               FontSize="16"
                               Foreground="LightGray"
                               Margin="0,0,0,5" />

                            <!-- Key -->
                            <TextBlock Grid.Row="1"
                               Text="Key:"
                               Foreground="Gray"
                               VerticalAlignment="Center"
                               Margin="5" />
                            <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding Key}"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="5" />

                            <!-- EditorID -->
                            <TextBlock Grid.Row="2"
                               Text="EditorID:"
                               Foreground="Gray"
                               VerticalAlignment="Center"
                               Margin="5" />
                            <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="{Binding EditorID}"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="5" />

                            <!-- Name -->
                            <TextBlock Grid.Row="3"
                               Text="Name:"
                               Foreground="Gray"
                               VerticalAlignment="Center"
                               Margin="5" />
                            <TextBox Grid.Row="3"
                                 Grid.Column="1"
                                 Text="{Binding Name}"
                                 Margin="5"
                                 Background="#444"
                                 BorderBrush="#555"
                                 Foreground="White" />

                            <!-- Cast Type -->
                            <TextBlock Grid.Row="4"
                               Text="Cast Type:"
                               Foreground="Gray"
                               VerticalAlignment="Center"
                               Margin="5" />
                            <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               Text="{Binding CastType}"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="5" />

                            <!-- Target Type -->
                            <TextBlock Grid.Row="5"
                               Text="Target Type:"
                               Foreground="Gray"
                               VerticalAlignment="Center"
                               Margin="5" />
                            <TextBlock Grid.Row="5"
                               Grid.Column="1"
                               Text="{Binding TargetType}"
                               Foreground="White"
                               VerticalAlignment="Center"
                               Margin="5" />

                            <!-- Enchantment Cost -->
                            <TextBlock Grid.Row="6"
                               Text="Cost:"
                               Foreground="Gray"
                               VerticalAlignment="Center"
                               Margin="5" />
                            <TextBox Grid.Row="6"
                               Grid.Column="1"
                               Text="{Binding EnchantmentCost}"
                               Margin="5"
                               Background="#444"
                               BorderBrush="#555"
                               Foreground="White" />
                        </Grid>
                    </StackPanel>

                    <!-- EFFECTS -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Effects"
                                   FontSize="16"
                                   Foreground="LightGray"
                                   Margin="0,0,0,5"/>

                        <ItemsControl ItemsSource="{Binding DataContext.EffectVMs, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="Gray" BorderThickness="1" Padding="5" Margin="0,0,0,5">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <!-- EditorID -->
                                                    <RowDefinition Height="Auto" />
                                                    <!-- Name -->
                                                    <RowDefinition Height="Auto" />
                                                    <!-- MagicEffectKey -->
                                                    <RowDefinition Height="Auto" />
                                                    <!-- Magnitude -->
                                                    <RowDefinition Height="Auto" />
                                                    <!-- Duration -->
                                                    <RowDefinition Height="Auto" />
                                                    <!-- Area -->
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!--ComboBox
                                                    ItemsSource="{Binding AllMagicEffects}"
                                                    DisplayMemberPath="Name"
                                                    SelectedItem="{Binding SelectedMagicEffect, Mode=TwoWay}" /-->


                                                    <TextBlock Grid.Row="1" Text="EditorID:" Width="120" Foreground="Gray"/>
                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Model.EditorID}" IsEnabled="False" Margin="5" Background="#444" BorderBrush="#555" Foreground="White"/>

                                                    <TextBlock Grid.Row="2" Text="Name:" Width="120" Foreground="Gray"/>
                                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Model.Name}" IsEnabled="False" Margin="5" Background="#444" BorderBrush="#555" Foreground="White"/>

                                                    <TextBlock Grid.Row="3" Text="Key:" Width="120" Foreground="Gray"/>
                                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Model.MagicEffectKey}" IsEnabled="False" Margin="5" Background="#444" BorderBrush="#555" Foreground="White"/>

                                                    <TextBlock Grid.Row="4" Text="Magnitude:" Width="120" Foreground="Gray"/>
                                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Model.Magnitude}" IsEnabled="{Binding AllowsMagnitude}" Margin="5" Background="#444" BorderBrush="#555" Foreground="White"/>

                                                    <TextBlock Grid.Row="5" Text="Duration:" Width="120" Foreground="Gray"/>
                                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Model.Duration}" IsEnabled="{Binding AllowsDuration}" Margin="5" Background="#444" BorderBrush="#555" Foreground="White"/>

                                                    <TextBlock Grid.Row="6" Text="Area:" Width="120" Foreground="Gray"/>
                                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Model.Area}" IsEnabled="{Binding AllowsArea}" Margin="5" Background="#444" BorderBrush="#555" Foreground="White"/>
                                            
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- WORN RESTRICTIONS -->
                    <!-- Keywords -->
                    <!-- Top View -->
                    <StackPanel Grid.Row="3">
                        <TextBlock Text="Worn Restrictions"
                            FontSize="16"
                            Foreground="LightGray"
                            Margin="0,0,0,5"/>
                        <DockPanel Margin="0,5">
                            <CheckBox Content="All Keywords (Expert)"
                                IsChecked="{Binding DataContext.ShowAllKeywords, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Foreground="White"
                                DockPanel.Dock="Right"
                                VerticalAlignment="Center"
                                Margin="10,0" />
                            <TextBlock Text="Search:"
                                 Foreground="White"
                                 VerticalAlignment="Center"
                                 Margin="0,0,5,0" />
                            <TextBox Text="{Binding DataContext.CurrentSearch, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}"
                               Background="#333"
                               Foreground="White" />
                        </DockPanel>

                        <GroupBox Header="Selected Keywords"
                            Foreground="White"
                            Margin="0,0,0,10"
                            Padding="10">

                            <ItemsControl ItemsSource="{Binding DataContext.KeywordItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4"
                                            Padding="5"
                                            Margin="3"
                                            Background="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}"
                                            Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">

                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                    Command="{Binding ToggleSelectedCommand}" />
                                            </Border.InputBindings>

                                            <TextBlock Text="{Binding Name}"
                                                Foreground="White"
                                                TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </GroupBox>
                        <!-- Bottom View -->

                        <GroupBox Header="Keywords"
                            Foreground="White"
                            Margin="0,0,0,15"
                            Padding="10">

                            <ItemsControl ItemsSource="{Binding DataContext.KeywordItems, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4"
                                            Padding="5"
                                            Margin="3"
                                            ToolTip="{Binding Key}"
                                            Background="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}">

                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                    Command="{Binding ToggleSelectedCommand}" />
                                            </Border.InputBindings>

                                            <TextBlock Text="{Binding Name}"
                                                Foreground="White"
                                                HorizontalAlignment="Center"
                                                TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </GroupBox>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

    </Grid>
</UserControl>
