<Window x:Class="SkyrimCraftingTool.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SkyrimCraftingTool.ViewModel"
        xmlns:views="clr-namespace:SkyrimCraftingTool.View"
        Title="Skyrim Crafting Tool"
        MinWidth="900" MinHeight="700"
        Background="#333">

    <Window.Resources>

        <DataTemplate DataType="{x:Type vm:MainContentVM}">
            <views:MainContentView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:EnchantmentMenuVM}">
            <views:EnchantmentMenuView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CategoriesConfigVM}">
            <views:CategoriesConfigView />
        </DataTemplate>

    </Window.Resources>


    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#333">
            <Button Content="Items"
                    Command="{Binding OpenMainContentCommand}"
                    Width="150" Height="30"
                    Margin="0,0,10,0" Padding="10,5"
                    Background="#555" Foreground="White"/>
            <Button Content="Enchantments"
                    Command="{Binding OpenEnchantmentMenuCommand}" 
                    Width="150" Height="30"
                    Margin="0,0,10,0" Padding="10,5"
                    Background="#555" Foreground="White"/>

            <Button Content="Categories"
                    Command="{Binding OpenCategoriesConfigCommand}" 
                    Width="150" Height="30"
                    Margin="0,0,10,0" Padding="10,5"
                    Background="#555" Foreground="White"/>
        </StackPanel>

        <ContentControl Content="{Binding CurrentView}" />
    </DockPanel>
</Window>