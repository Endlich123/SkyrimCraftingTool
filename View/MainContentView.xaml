<UserControl x:Class="SkyrimCraftingTool.View.MainContentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SkyrimCraftingTool.ViewModel"
             xmlns:model="clr-namespace:SkyrimCraftingTool.Model"
             Loaded="MainContentView_Loaded">

    <DockPanel LastChildFill="True">

        <!-- Oben: Debug / Aktionen -->
        <StackPanel Orientation="Vertical"
                    DockPanel.Dock="Top"
                    Margin="6"
                    Width="250"
                    HorizontalAlignment="Left">
            <Button Content="Scan DB"
                    Command="{Binding ScanModsCommand}"
                    Margin="6,0,0,0"
                    Padding="8,4"
                    Background="#2E8B57"
                    Foreground="White" />
            <TextBlock Foreground="Yellow"
                       Margin="0,0,10,0"
                       Text="{Binding FilteredTree.Count, StringFormat=TreeCount: {0}}" />
        </StackPanel>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LINKS: Tree + Suche -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Suche -->
                <TextBox Grid.Row="0"
                         Text="{Binding TreeSearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Suche Plugin/Item..."
                         Background="#222"
                         Foreground="White"
                         BorderBrush="#555"
                         Padding="5"
                         Margin="0,0,0,5" />

                <!-- Expand / Collapse -->
                <UniformGrid Grid.Row="1"
                             Columns="1"
                             Margin="0,0,0,5">
                    <Button Content="Collapse all [-]"
                            Command="{Binding CollapseAllCommand}"
                            Margin="0,0,2,0"
                            Background="#444"
                            Foreground="White" />
                    <!--Button Content="Alle [+]"
                            Command="{Binding ExpandAllCommand}"
                            Margin="2,0,0,0"
                            Background="#444"
                            Foreground="White" /-->
                </UniformGrid>

                <!-- TreeView -->
                <TreeView Grid.Row="2"
                          x:Name="MainTreeView"
                          ItemsSource="{Binding FilteredTree}"
                          VirtualizingPanel.IsVirtualizing="True"
                          SelectedItemChanged="MainTreeView_SelectedItemChanged"
                          Background="#333">

                    <!-- Container-Style -->
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{x:Null}">
                            <Setter Property="Padding" Value="2" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />

                            <Style.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#444"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#333"/>
                            </Style.Resources>
                        </Style>
                    </TreeView.ItemContainerStyle>

                    <!-- Header-Templates -->
                    <TreeView.Resources>

                        <!-- Plugin -->
                        <HierarchicalDataTemplate DataType="{x:Type local:PluginNodeVM}"
                                                  ItemsSource="{Binding Categories}">
                            <TextBlock Text="{Binding PluginName}"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       IsHitTestVisible="False" />
                        </HierarchicalDataTemplate>

                        <!-- Kategorie -->
                        <HierarchicalDataTemplate DataType="{x:Type local:CategoryNodeVM}"
                                                  ItemsSource="{Binding Items}">
                            <TextBlock Text="{Binding CategoryName}"
                                       Foreground="LightSteelBlue"
                                       IsHitTestVisible="False" />
                        </HierarchicalDataTemplate>

                        <!-- Item -->
                        <DataTemplate DataType="{x:Type local:ItemNodeVM}">
                            <TextBlock Text="{Binding EditorID}"
                                       Foreground="LightGray"
                                       IsHitTestVisible="False" />
                        </DataTemplate>

                    </TreeView.Resources>
                </TreeView>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="#444" />

            <!-- RECHTS: Detailansicht -->
            <ContentPresenter Grid.Column="2"
                              Content="{Binding SelectedNode}"
                              Width="Auto">
                <ContentPresenter.Resources>

                    <!-- ITEM-DETAIL -->
                    <DataTemplate DataType="{x:Type local:ItemNodeVM}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Grid >
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <!-- Presets -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- Item Details -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- Armor/Weapon Details -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- Keywords -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- Materials -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- Temper -->
                                        <RowDefinition Height="Auto"/>
                                        <!-- Container -->
                                    </Grid.RowDefinitions>

                                    <!-- Preset-Zeile -->
                                    <Border Grid.Row="0"
                                    Background="#2A2A2A"
                                    Padding="5"
                                    Margin="0,0,0,10">
                                        <DockPanel LastChildFill="False">
                                            <ComboBox ItemsSource="{Binding ConfigPresets}"
                                              SelectedItem="{Binding SelectedConfigPreset}"
                                              Width="180"
                                              Background="#444"
                                              Foreground="White"
                                              Margin="0,0,10,0" />
                                            <Button Content="Apply"
                                            Command="{Binding ApplyPresetCommand}"
                                            Background="#555"
                                            Foreground="White"
                                            Margin="0,0,10,0" />
                                        </DockPanel>
                                    </Border>

                                    <!-- Item Details -->
                                    <GroupBox Grid.Row="1" Margin="0,0,0,15" Padding="10">
                                        <GroupBox.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Item Details"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>

                                                <Button
                                                Margin="10,0,0,0"
                                                ToolTip="Shows the fundamental properties of an item."
                                                Style="{StaticResource InfoButtonStyle}"/>
                                            </StackPanel>
                                        </GroupBox.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>



                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <!-- EditorID -->
                                                <RowDefinition Height="Auto" />
                                                <!-- Key -->
                                                <RowDefinition Height="Auto" />
                                                <!-- Name -->
                                                <RowDefinition Height="Auto" />
                                                <!-- Cost -->
                                                <RowDefinition Height="Auto" />
                                                <!-- Weight -->
                                            </Grid.RowDefinitions>

                                            <!-- EditorID -->
                                            <TextBlock Grid.Row="0"
                                           Text="EditorID:"
                                           Style="{StaticResource ItemLabelStyle}"/>

                                            <TextBox Grid.Row="0"
                                             Grid.Column="1"
                                             Text="{Binding EditorID}"
                                             IsEnabled="False"
                                             IsReadOnly="True"
                                             Style="{StaticResource ItemTextBoxStyle}"/>

                                            <Button Grid.Row="0"
                                            Grid.Column="2"
                                            ToolTip="Internal name used by the Creation Engine. Not relevant for gameplay."
                                            Style="{StaticResource InfoButtonStyle}"/>


                                            <!-- Key -->
                                            <TextBlock Grid.Row="1"
                                           Text="Key:"
                                           Style="{StaticResource ItemLabelStyle}"/>

                                            <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Text="{Binding Key}"
                                             IsEnabled="False"
                                             IsReadOnly="True" 
                                             Style="{StaticResource ItemTextBoxStyle}"
                                             />

                                            <Button Grid.Row="1"
                                            Grid.Column="2"
                                            ToolTip="Generated as PluginName | MasterPluginName | FormID. If PluginName = MasterPluginName: the item is Original. If PluginName ≠ MasterPluginName: the item is an Override."
                                            Style="{StaticResource InfoButtonStyle}"/>

                                            <!-- Name -->
                                            <TextBlock Grid.Row="2"
                                           Text="Name:"
                                           Style="{StaticResource ItemLabelStyle}"/>

                                            <TextBox Grid.Row="2"
                                                 Grid.Column="1"
                                                 Text="{Binding Name}"
                                                 Style="{StaticResource ItemTextBoxStyle}"/>

                                            <Button Grid.Row="2"
                                                Grid.Column="2"
                                                ToolTip="The in‑game display name of the item."
                                                Style="{StaticResource InfoButtonStyle}"/>

                                            <!-- Cost -->
                                            <TextBlock Grid.Row="3"
                                               Text="Cost:"
                                               Style="{StaticResource ItemLabelStyle}"/>

                                            <TextBox Grid.Row="3"
                                             Grid.Column="1"
                                             Text="{Binding Value}"
                                             Style="{StaticResource ItemTextBoxStyle}"/>

                                            <Button Grid.Row="3"
                                            Grid.Column="2"
                                            ToolTip="The base monetary value. The final price depends on your Speech skill, perks, buffs, and debuffs."
                                            Style="{StaticResource InfoButtonStyle}"/>

                                            <!-- Weight -->
                                            <TextBlock Grid.Row="4"
                                           Text="Weight:"
                                           Style="{StaticResource ItemLabelStyle}"/>

                                            <TextBox Grid.Row="4"
                                             Grid.Column="1"
                                             Text="{Binding Weight}"
                                             Style="{StaticResource ItemTextBoxStyle}"/>

                                            <Button Grid.Row="4"
                                            Grid.Column="2"
                                            ToolTip="How heavy the item is."
                                            Style="{StaticResource InfoButtonStyle}"/>
                                        </Grid>
                                    </GroupBox>

                                    <!-- Armor / Weapon Specific Details -->
                                    <GroupBox Grid.Row="2"
                                    Foreground="White"
                                    Margin="0,0,0,15"
                                    Padding="10">
                                        <GroupBox.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Armor / Weapon Specific Details"
                                               Foreground="White"
                                               VerticalAlignment="Center"/>

                                                <Button
                                                Margin="10,0,0,0"
                                                ToolTip="This Block shows the Armor / Weapon Specific Details of an item."
                                                Style="{StaticResource InfoButtonStyle}"/>
                                            </StackPanel>
                                        </GroupBox.Header>

                                        <VirtualizingStackPanel>

                                            <!-- ARMOR -->
                                            <StackPanel Visibility="{Binding IsArmor, Converter={StaticResource BoolToVis}}">
                                                
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    
                                                    <!-- ArmorRating -->
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Armor Rating:" Style="{StaticResource ItemLabelStyle}"/>

                                                    <TextBox Grid.Row="0" Grid.Column="1"
                                                         Text="{Binding ArmorRating}"
                                                         Style="{StaticResource ItemTextBoxStyle}"/>

                                                    <Button Grid.Row="0" Grid.Column="2"
                                                        ToolTip="How much incoming physical damage is reduced."
                                                        Style="{StaticResource InfoButtonStyle}"/>
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Body Slots:" Style="{StaticResource ItemLabelStyle}"/>

                                                    <Button Grid.Row="0" Grid.Column="1"
                                                        ToolTip="Defines where the item is equipped. Items can use multiple slots. If two items share a slot, you cannot equip both at the same time." 
                                                        Style="{StaticResource InfoButtonStyle}"/>
                                                </Grid>

                                                <ItemsControl ItemsSource="{Binding SlotOptions}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>

                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="4"
                                                            Padding="5"
                                                            Margin="3"
                                                            Background="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}">

                                                                <Border.InputBindings>
                                                                    <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding ToggleSelectedCommand}" />
                                                                </Border.InputBindings>

                                                                <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="White"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                            </StackPanel>

                                            <!-- WEAPON -->
                                            <StackPanel Visibility="{Binding IsWeapon, Converter={StaticResource BoolToVis}}">
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <!-- Label -->
                                                        <ColumnDefinition Width="*"/>
                                                        <!-- Value -->
                                                        <ColumnDefinition Width="Auto"/>
                                                        <!-- Info Button -->
                                                    </Grid.ColumnDefinitions>

                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <!-- DAMAGE -->
                                                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Damage:" Style="{StaticResource ItemLabelStyle}"/>
                                                    <TextBox Grid.Column="1"
                                                         Text="{Binding Damage}"
                                                         Style="{StaticResource ItemTextBoxStyle}"/>
                                                    <Button Grid.Column="2"
                                                            ToolTip="The weapon’s base damage before modifiers. Temper improvements, skills, perks, and debuffs modify this value."
                                                            Style="{StaticResource InfoButtonStyle}"/>

                                                    <!-- SPEED -->
                                                    <TextBlock Grid.Column="0" Grid.Row="1" Text="Speed:" Style="{StaticResource ItemLabelStyle}"/>
                                                    <TextBox Grid.Column="1" Grid.Row="1"
                                                         Text="{Binding Speed}"
                                                         Style="{StaticResource ItemTextBoxStyle}"/>
                                                    <Button Grid.Column="2" Grid.Row="1"
                                                        ToolTip="How fast the weapon swings."
                                                        Style="{StaticResource InfoButtonStyle}"/>

                                                    <!-- REACH -->
                                                    <TextBlock Grid.Column="0" Grid.Row="2" Text="Reach:" Style="{StaticResource ItemLabelStyle}"/>
                                                    <TextBox Grid.Column="1" Grid.Row="2"
                                                         Text="{Binding Reach}"
                                                         Style="{StaticResource ItemTextBoxStyle}"/>
                                                    <Button Grid.Column="2" Grid.Row="2"
                                                        ToolTip="How far the weapon can hit. Changing this usually feels unnatural unless you know exactly what you're doing."
                                                        Style="{StaticResource InfoButtonStyle}"/>

                                                    <!-- STAGGER -->
                                                    <TextBlock Grid.Column="0" Grid.Row="3" Text="Stagger:" Style="{StaticResource ItemLabelStyle}"/>
                                                    <TextBox Grid.Column="1" Grid.Row="3"
                                                     Text="{Binding Stagger}"
                                                     Style="{StaticResource ItemTextBoxStyle}"/>
                                                    <Button Grid.Column="2" Grid.Row="3"
                                                    ToolTip="Controls how much stagger the weapon inflicts on hit."
                                                    Style="{StaticResource InfoButtonStyle}"/>
                                                </Grid>
                                            </StackPanel>


                                        </VirtualizingStackPanel>
                                    </GroupBox>


                                    <!-- Keywords -->
                                    <!-- Top View -->
                                    <StackPanel Grid.Row="3">
                                        <DockPanel Margin="0,5">
                                            <CheckBox Content="All Keywords (Expert)"
                                                IsChecked="{Binding ShowAllKeywords}"
                                                Foreground="White"
                                                DockPanel.Dock="Right"
                                                VerticalAlignment="Center"
                                                Margin="10,0" />
                                            <TextBlock Text="Search:"
                                                 Foreground="White"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,5,0" />
                                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                   Background="#333"
                                                   Foreground="White" />
                                        </DockPanel>

                                        <GroupBox
                                        Foreground="White"
                                        Margin="0,0,0,10"
                                        Padding="10">

                                            <GroupBox.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Selected Keywords"
                                                       Foreground="White"
                                                       VerticalAlignment="Center"/>

                                                    <Button
                                                    Margin="10,0,0,0"
                                                    ToolTip="Shows which keywords are currently applied to the item."
                                                    Style="{StaticResource InfoButtonStyle}"/>
                                                </StackPanel>
                                            </GroupBox.Header>

                                            <ItemsControl ItemsSource="{Binding SelectedKeywordsView}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="4"
                                                        Padding="5"
                                                        Margin="3"
                                                        Background="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}">

                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                Command="{Binding ToggleSelectedCommand}" />
                                                            </Border.InputBindings>

                                                            <TextBlock Text="{Binding Name}"
                                                            Foreground="White"
                                                            TextTrimming="CharacterEllipsis"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </GroupBox>
                                        <!-- Bottom View -->

                                        <GroupBox
                                        Foreground="White"
                                        Margin="0,0,0,15"
                                        Padding="10">

                                            <GroupBox.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Keywords"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>

                                                    <Button
                                                    Margin="10,0,0,0"
                                                    ToolTip="Shows all available keywords. Click to select, click again to unselect. Standard View: Only commonly used keywords for weapons/armor. Expert View: Loads all keywords from your entire modlist. Only recommended if you know exactly what each keyword does."
                                                    Style="{StaticResource InfoButtonStyle}"/>
                                                </StackPanel>
                                            </GroupBox.Header>

                                            <ItemsControl ItemsSource="{Binding FilteredKeywordsView}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"
                                                        ItemWidth="{Binding DataContext.KeywordItemWidth,
                                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        ItemHeight="{Binding DataContext.KeywordItemHeight,
                                                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="4"
                                                        Padding="5"
                                                        Margin="3"
                                                        ToolTip="{Binding Key}">

                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}"/>
                                                                    <Style.Triggers>
                                                                        <!-- Weapon-type keywords: visually highlight and make read-only -->
                                                                        <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                                                            <Setter Property="Background" Value="#8B0000"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>

                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                Command="{Binding ToggleSelectedCommand}" />
                                                            </Border.InputBindings>

                                                            <TextBlock Text="{Binding Name}"
                                                            FontSize="{Binding DataContext.KeywordFontSize,
                                                                               RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            Foreground="White"
                                                            HorizontalAlignment="Center"
                                                            TextTrimming="CharacterEllipsis"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </GroupBox>
                                    </StackPanel>


                                    <!-- Crafting / Recipe -->
                                    <GroupBox Grid.Row="4"
                                                Foreground="White"
                                                Padding="10">
                                        <GroupBox.Header>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="Crafting Recipe"
                                                Foreground="White"
                                                DockPanel.Dock="Left" />
                                                <Button Content="+"
                                                Command="{Binding AddIngredientCommand}"
                                                ToolTip="Add Material"
                                                Width="25"
                                                Height="25"
                                                Margin="10,0,0,0"
                                                DockPanel.Dock="Right"
                                                Background="#444"
                                                Foreground="White"
                                                BorderBrush="#666"
                                                FontWeight="Bold" />
                                                <Button
                                                    Margin="10,0,0,0"
                                                    ToolTip="Shows the crafting recipe for creating the item."
                                                    Style="{StaticResource InfoButtonStyle}"/>

                                            </DockPanel>
                                        </GroupBox.Header>
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <!-- COBJ Origin Key -->
                                                    <RowDefinition Height="Auto" />
                                                    <!-- Workbench -->
                                                    <RowDefinition Height="Auto" />
                                                    <!-- Perk -->
                                                </Grid.RowDefinitions>

                                                <!-- COBJ Origin Key -->
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="COBJ Origin Key: "
                                               Style="{StaticResource ItemLabelStyle}"/>

                                                <TextBox Grid.Row="0" Grid.Column="1"
                                                 Text="{Binding CraftingEditorID, Mode=OneWay}"
                                                 Style="{StaticResource ItemTextBoxStyle}"
                                                 IsEnabled="False"/>

                                                <Button Grid.Row="0" Grid.Column="2"
                                                Style="{StaticResource InfoButtonStyle}"
                                                ToolTip="The key of the original recipe: MasterPluginName | FormID."/>


                                                <!-- Workbench -->
                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="Workbench:"
                                                   Style="{StaticResource ItemLabelStyle}"/>

                                                <ComboBox Grid.Row="1" Grid.Column="1"
                                                      ItemsSource="{Binding AllAvailableWorkbenches}"
                                                      SelectedValuePath="Key"
                                                      SelectedValue="{Binding CraftingWorkbenchKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      ToolTip="{Binding SelectedValue, RelativeSource={RelativeSource Self}}"
                                                      IsEditable="True"
                                                      IsTextSearchEnabled="False"
                                                      StaysOpenOnEdit="True"
                                                      TextSearch.TextPath="Name"
                                                      Style="{StaticResource ItemComboBoxStyle}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}" ToolTip="{Binding Key}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>

                                                <Button Grid.Row="1" Grid.Column="2"
                                                    ToolTip="The crafting station where the item can be created. Recommended: SkyrimSmithingForge (the standard forge)." 
                                                    Style="{StaticResource InfoButtonStyle}"/>


                                                <!-- Perk -->
                                                <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="Perk:"
                                                   Style="{StaticResource ItemLabelStyle}"/>

                                                <ComboBox Grid.Row="2" Grid.Column="1"
                                                  ItemsSource="{Binding AllAvailablePerks}"
                                                  SelectedValuePath="Key"
                                                  SelectedValue="{Binding CraftingPerkKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ToolTip="{Binding SelectedValue, RelativeSource={RelativeSource Self}}"
                                                  IsEditable="True"
                                                  IsTextSearchEnabled="False"
                                                  StaysOpenOnEdit="True"
                                                  TextSearch.TextPath="Name"
                                                  Style="{StaticResource ItemComboBoxStyle}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Name}" ToolTip="{Binding Key}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>

                                                <Button Grid.Row="2" Grid.Column="2"
                                                ToolTip="The perk needed to unlock the recipe. Example: SteelSmithing requires leveling Smithing and unlocking the perk in-game." 
                                                Style="{StaticResource InfoButtonStyle}"/>

                                            </Grid>

                                            <Border BorderBrush="Gray" BorderThickness="0,0,0,1" Margin="0,5,0,5"/>
                                            <ItemsControl ItemsSource="{Binding CraftingIngredients}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="60" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <ComboBox Grid.Column="0"
                                                                  ItemsSource="{Binding LocalMaterialsView}"
                                                                  SelectedItem="{Binding SelectedMaterial}"
                                                                  Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                                  ToolTip="{Binding Key}"
                                                                  DisplayMemberPath="Name"
                                                                  IsEditable="True"
                                                                  IsTextSearchEnabled="False"
                                                                  StaysOpenOnEdit="True"
                                                                  Style="{StaticResource ItemComboBoxStyle}"/>

                                                            <TextBox Grid.Column="1"
                                                                 TextAlignment="Center"
                                                                 ToolTip="Amount"
                                                                 Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource ItemTextBoxStyle}"/>

                                                            <Button Grid.Column="2"
                                                                Command="{Binding DataContext.RemoveIngredientCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="Remove Material"
                                                                Style="{StaticResource RemoveButtonStyle}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </GroupBox>

                                    <!-- Temper Recipe -->
                                    <GroupBox Grid.Row="5"
                                        Foreground="White"
                                        Margin="0,15,0,0"
                                        Padding="10">
                                        <GroupBox.Header>
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="Temper Recipe"
                                                    Foreground="White"
                                                    DockPanel.Dock="Left" />
                                                <Button Content="+"
                                                    Command="{Binding AddTemperIngredientCommand}"
                                                    ToolTip="Add Material"
                                                    Width="25"
                                                    Height="25"
                                                    Margin="10,0,0,0"
                                                    DockPanel.Dock="Right"
                                                    Background="#444"
                                                    Foreground="White"
                                                    BorderBrush="#666"
                                                    FontWeight="Bold" />
                                                <Button
                                                    Margin="10,0,0,0"
                                                    ToolTip="Shows the recipe used to improve (temper) the item."
                                                    Style="{StaticResource InfoButtonStyle}"/>
                                            </DockPanel>
                                        </GroupBox.Header>

                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <!-- COBJ Origin Key -->
                                                    <RowDefinition Height="Auto" />
                                                    <!-- Workbench -->
                                                    <RowDefinition Height="Auto" />
                                                    <!-- Perk -->
                                                </Grid.RowDefinitions>
                                                
                                                <!-- COBJ Origin Key -->
                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                        Text="COBJ Origin Key: "
                                                        Style="{StaticResource ItemLabelStyle}"
                                                        />
                                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding TemperEditorID, Mode=OneWay}"
                                                         IsEnabled="False"
                                                       Style="{StaticResource ItemTextBoxStyle}"/>
                                                <Button Grid.Row="0" Grid.Column="2"
                                                        ToolTip="The key of the original temper recipe: MasterPluginName | FormID."
                                                        Style="{StaticResource InfoButtonStyle}"/>

                                                <!-- Workbench -->

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Workbench: " Style="{StaticResource ItemLabelStyle}"/>

                                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TemperWorkbenchKey, Mode=OneWay}"
                                                     IsEnabled="False"
                                                   Style="{StaticResource ItemTextBoxStyle}"/>
                                                <Button Grid.Row="1" Grid.Column="2"
                                                        ToolTip="Tempering uses only two workbenches: Sharpening Wheel (Weapons), Armor Workbench (Armor). This is handled automatically."
                                                        Style="{StaticResource InfoButtonStyle}"/>
                                                <!-- Perk -->
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Perk: " Style="{StaticResource ItemLabelStyle}"/>


                                                <ComboBox Grid.Row="2" Grid.Column="1"
                                                        ItemsSource="{Binding AllAvailablePerks}"
                                                        SelectedValuePath="Key"
                                                        SelectedValue="{Binding TemperPerkKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        ToolTip="{Binding SelectedValue, RelativeSource={RelativeSource Self}}"
                                                        IsEditable="True"
                                                        IsTextSearchEnabled="False"
                                                        StaysOpenOnEdit="True"
                                                        TextSearch.TextPath="Name"   
                                                        Style="{StaticResource ItemComboBoxStyle}">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Name}" ToolTip="{Binding Key}" />
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>

                                                <Button Grid.Row="2" Grid.Column="2"
                                                    ToolTip="The perk needed to improve the item beyond basic levels. Example: SteelSmithing allows higher tempering tiers for steel items."
                                                    Style="{StaticResource InfoButtonStyle}"/>
                                            </Grid>
                                            <Border BorderBrush="Gray" BorderThickness="0,0,0,1" Margin="0,5,0,5"/>
                                            <ItemsControl ItemsSource="{Binding TemperIngredients}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="60" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>

                                                            <ComboBox Grid.Column="0"
                                                            ItemsSource="{Binding LocalMaterialsView}"
                                                            SelectedItem="{Binding SelectedMaterial}"
                                                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                            ToolTip="{Binding Key}"
                                                            DisplayMemberPath="Name"
                                                            IsEditable="True"
                                                            IsTextSearchEnabled="False"
                                                            StaysOpenOnEdit="True"
                                                            Style="{StaticResource ItemComboBoxStyle}"/>

                                                            <TextBox Grid.Column="1"
                                                           TextAlignment="Center"
                                                           Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}"
                                                           Style="{StaticResource ItemTextBoxStyle}"/>

                                                            <Button Grid.Column="2"
                                                            ToolTip="Remove Material"
                                                            Command="{Binding DataContext.RemoveTemperIngredientCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource RemoveButtonStyle}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </GroupBox>
                                    <!-- Container Section -->
                                    <GroupBox Grid.Row="6"
                                     Foreground="White"
                                     Margin="0,15,0,0"
                                     Padding="10">
                                        <GroupBox.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Container"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>

                                                <Button
                                                    Margin="10,0,0,0"
                                                    ToolTip="Shows where the item can appear in containers or merchant inventories. A Container can be a chest, NPC inventory, or merchant. Standard View: Only merchants are shown. Expert View: All containers in your modlist are displayed. Selecting a container shows its details on the right side. If the container uses Leveled Item Lists, you can add the item there as well. Use the level slider to define at which player level the item becomes available."
                                                    Style="{StaticResource InfoButtonStyle}"/>
                                            </StackPanel>
                                        </GroupBox.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="3*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Left: All Containers (read-only overview) -->
                                            <!-- Left: All Containers (limited or full, depending on expert mode) -->
                                            <StackPanel Grid.Column="0">

                                                <!-- Search -->
                                                <TextBox 
                                                Text="{Binding DataContext.ContainerSearchText, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Margin="0,0,0,6"
                                                />

                                                <!-- Expert toggle -->
                                                <Button Content="{Binding DataContext.ShowExpertContainers, 
                                                      RelativeSource={RelativeSource AncestorType=UserControl},
                                                      Converter={StaticResource BoolToExpertTextConverter}}"
                                                            Command="{Binding DataContext.ToggleExpertContainersCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            Background="#444"
                                                            Foreground="White"
                                                            Margin="0,0,0,10"
                                                            />

                                                <TextBlock Text="Containers" Foreground="LightGray" Margin="0,0,0,6"/>

                                                <ScrollViewer Height="180" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl ItemsSource="{Binding DataContext.FilteredContainers, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Padding="6" Margin="0,0,0,6" Background="#2A2A2A" CornerRadius="4">
                                                                    <DockPanel>
                                                                        <TextBlock Text="{Binding Name}" Foreground="White" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                                                        <Button Width="70"
                                                                            HorizontalAlignment="Right"
                                                                            Background="#444"
                                                                            Foreground="White"
                                                                            DockPanel.Dock="Right"
                                                                            Command="{Binding DataContext.ToggleContainerForSelectedItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding ContainerKey}"
                                                                            Content="{Binding IsSelected, Converter={StaticResource BoolToSelectTextConverter}}" />
                                                                    </DockPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </StackPanel>


                                            <!-- Split -->
                                            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#333"/>

                                            <!-- Right: Selected Containers + LVLi (editable for current item) -->
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Selected Containers (for this item)" Foreground="LightGray" Margin="0,0,0,6"/>

                                                <!-- Bind to SelectedNode on the Main VM -->
                                                <ItemsControl ItemsSource="{Binding DataContext.SelectedNode.ContainerSelection.SelectedContainers, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="8" Margin="0,0,0,8" Background="#2A2A2A" CornerRadius="4">
                                                                <StackPanel>
                                                                    <DockPanel>
                                                                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" DockPanel.Dock="Left"/>
                                                                        <Button Content="Remove"
                                                                                Width="60"
                                                                                DockPanel.Dock="Right"
                                                                                Command="{Binding ToggleSelectedCommand}"
                                                                                Background="#444"
                                                                                Foreground="White"/>
                                                                    </DockPanel>

                                                                    <ItemsControl ItemsSource="{Binding LVLiEntries}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Grid Margin="0,6,0,6">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*" />
                                                                                        <ColumnDefinition Width="180" />
                                                                                    </Grid.ColumnDefinitions>

                                                                                    <TextBlock  Grid.Column="0" Text="{Binding LVLiName}" Foreground="White" VerticalAlignment="Center" />
                                                                                    <StackPanel  Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                                        <Slider Minimum="0" Maximum="100"
                                                                                        Value="{Binding LevelDouble, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                                                        SmallChange="1" LargeChange="1" TickFrequency="1"
                                                                                        Width="120"
                                                                                        Thumb.DragCompleted="Slider_ThumbDragCompleted" 
                                                                                        />
                                                                                        <TextBlock Text="{Binding Level}" Margin="8,0,0,0" Foreground="White" VerticalAlignment="Center"/>
                                                                                    </StackPanel>
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                                    <Button Content="Clear Selection" Width="120" Margin="6,0,0,0"
                                                        Command="{Binding DataContext.ClearContainerSelectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        Background="#444" Foreground="White"/>
                                                </StackPanel>
                                            </StackPanel>

                                        </Grid>
                                    </GroupBox>


                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </DataTemplate>


                    <!-- PLUGIN-DETAIL -->
                    <DataTemplate DataType="{x:Type local:PluginNodeVM}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="20">
                                <TextBlock Text="{Binding PluginName}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#FFD700"
                                           Margin="0,0,0,20" />

                                <GroupBox Header="Auto-Apply Settings (Auf alle Items der Mod anwenden)"
                                          Foreground="White"
                                          Margin="0,0,0,15"
                                          Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="Standard Material:"
                                                   Foreground="Gray"
                                                   VerticalAlignment="Center"
                                                   Margin="5" />
                                        <ComboBox Grid.Column="1"
                                                  Margin="5"
                                                  Background="#444"
                                                  Foreground="Black" />
                                        <CheckBox Grid.Column="2"
                                                  Content="Anwenden"
                                                  IsChecked="{Binding ApplyMaterial}"
                                                  Foreground="White"
                                                  VerticalAlignment="Center"
                                                  Margin="5" />
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Händler-Verteilung (Massen-Zuweisung)"
                                          Foreground="White"
                                          Margin="0,0,0,15"
                                          Padding="10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Content="Add all items to Vendors"
                                                    Padding="10,5"
                                                    Margin="5"
                                                    Background="#444"
                                                    Foreground="White" />
                                        </Grid>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </DataTemplate>

                </ContentPresenter.Resources>
            </ContentPresenter>
        </Grid>
    </DockPanel>
</UserControl>
