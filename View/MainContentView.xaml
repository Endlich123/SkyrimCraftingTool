<UserControl x:Class="SkyrimCraftingTool.View.MainContentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:SkyrimCraftingTool.ViewModel"
             xmlns:model="clr-namespace:SkyrimCraftingTool.Model"
             Loaded="MainContentView_Loaded">

    <DockPanel LastChildFill="True">

        <!-- Oben: Debug / Aktionen -->
        <StackPanel Orientation="Vertical"
                    DockPanel.Dock="Top"
                    Margin="6"
                    Width="250"
                    HorizontalAlignment="Left">
            <Button Content="Scan DB"
                    Command="{Binding ScanModsCommand}"
                    Margin="6,0,0,0"
                    Padding="8,4"
                    Background="#2E8B57"
                    Foreground="White" />
            <TextBlock Foreground="Yellow"
                       Margin="0,0,10,0"
                       Text="{Binding FilteredTree.Count, StringFormat=TreeCount: {0}}" />
        </StackPanel>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LINKS: Tree + Suche -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Suche -->
                <TextBox Grid.Row="0"
                         Text="{Binding TreeSearchText, UpdateSourceTrigger=PropertyChanged}"
                         Tag="Suche Plugin/Item..."
                         Background="#222"
                         Foreground="White"
                         BorderBrush="#555"
                         Padding="5"
                         Margin="0,0,0,5" />

                <!-- Expand / Collapse -->
                <UniformGrid Grid.Row="1"
                             Columns="1"
                             Margin="0,0,0,5">
                    <Button Content="Collapse all [-]"
                            Command="{Binding CollapseAllCommand}"
                            Margin="0,0,2,0"
                            Background="#444"
                            Foreground="White" />
                    <!--Button Content="Alle [+]"
                            Command="{Binding ExpandAllCommand}"
                            Margin="2,0,0,0"
                            Background="#444"
                            Foreground="White" /-->
                </UniformGrid>

                <!-- TreeView -->
                <TreeView Grid.Row="2"
                          x:Name="MainTreeView"
                          ItemsSource="{Binding FilteredTree}"
                          SelectedItemChanged="MainTreeView_SelectedItemChanged"
                          Background="#333">

                    <!-- Container-Style -->
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{x:Null}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="Padding" Value="2" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />

                            <Style.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#444"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#333"/>
                            </Style.Resources>
                        </Style>
                    </TreeView.ItemContainerStyle>

                    <!-- Header-Templates -->
                    <TreeView.Resources>

                        <!-- Plugin -->
                        <HierarchicalDataTemplate DataType="{x:Type local:PluginNodeVM}"
                                                  ItemsSource="{Binding Categories}">
                            <TextBlock Text="{Binding PluginName}"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       IsHitTestVisible="False" />
                        </HierarchicalDataTemplate>

                        <!-- Kategorie -->
                        <HierarchicalDataTemplate DataType="{x:Type local:CategoryNodeVM}"
                                                  ItemsSource="{Binding Items}">
                            <TextBlock Text="{Binding CategoryName}"
                                       Foreground="LightSteelBlue"
                                       IsHitTestVisible="False" />
                        </HierarchicalDataTemplate>

                        <!-- Item -->
                        <DataTemplate DataType="{x:Type local:ItemNodeVM}">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="LightGray"
                                       IsHitTestVisible="False" />
                        </DataTemplate>

                    </TreeView.Resources>
                </TreeView>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="#444" />

            <!-- RECHTS: Detailansicht -->
            <ContentPresenter Grid.Column="2"
                              Content="{Binding SelectedNode}"
                              Width="Auto">
                <ContentPresenter.Resources>

                    <!-- ITEM-DETAIL -->
                    <DataTemplate DataType="{x:Type local:ItemNodeVM}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <!-- Presets -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Item Details -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Armor/Weapon Details -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Keywords -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Materials -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- Temper -->
                                </Grid.RowDefinitions>

                                <!-- Preset-Zeile -->
                                <Border Grid.Row="0"
                                    Background="#2A2A2A"
                                    Padding="5"
                                    Margin="0,0,0,10">
                                    <DockPanel LastChildFill="False">
                                        <ComboBox ItemsSource="{Binding ConfigPresets}"
                                              SelectedItem="{Binding SelectedConfigPreset}"
                                              Width="180"
                                              Background="#444"
                                              Foreground="White"
                                              Margin="0,0,10,0" />
                                        <Button Content="Apply"
                                            Command="{Binding ApplyPresetCommand}"
                                            Background="#555"
                                            Foreground="White"
                                            Margin="0,0,10,0" />
                                    </DockPanel>
                                </Border>

                                <!-- Item Details -->
                                <GroupBox Grid.Row="1"
                                      Header="Item Details"
                                      Foreground="White"
                                      Margin="0,0,0,15"
                                      Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="Name:"
                                               Foreground="Gray"
                                               VerticalAlignment="Center"
                                               Margin="5" />
                                        <TextBox Grid.Column="1"
                                             Text="{Binding Name}"
                                             Margin="5"
                                             Background="#444"
                                             Foreground="White"
                                             BorderBrush="#555" />

                                        <TextBlock Grid.Row="1"
                                               Text="Key:"
                                               Foreground="Gray"
                                               VerticalAlignment="Center"
                                               Margin="5" />
                                        <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Text="{Binding Key}"
                                             Margin="5"
                                             Background="#444"
                                             Foreground="White"
                                             BorderBrush="#555" />

                                        <TextBlock Grid.Row="2"
                                               Text="Cost:"
                                               Foreground="Gray"
                                               VerticalAlignment="Center"
                                               Margin="5" />
                                        <TextBox Grid.Row="2"
                                             Grid.Column="1"
                                             Text="{Binding Value}"
                                             Margin="5"
                                             Background="#444"
                                             Foreground="White"
                                             BorderBrush="#555" />

                                        <TextBlock Grid.Row="3"
                                               Text="Weight:"
                                               Foreground="Gray"
                                               VerticalAlignment="Center"
                                               Margin="5" />
                                        <TextBox Grid.Row="3"
                                             Grid.Column="1"
                                             Text="{Binding Weight}"
                                             Margin="5"
                                             Background="#444"
                                             Foreground="White"
                                             BorderBrush="#555" />
                                    </Grid>
                                </GroupBox>

                                <!-- Armor / Weapon Specific Details -->
                                <GroupBox Grid.Row="2"
                                    Header="Armor / Weapon Specific Details"
                                    Foreground="White"
                                    Margin="0,0,0,15"
                                    Padding="10">

                                    <StackPanel>

                                        <!-- ARMOR -->
                                        <StackPanel Visibility="{Binding IsArmor, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Armor Rating:" Foreground="Gray" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding ArmorRating}"
                                               Background="#444"
                                               Foreground="White"
                                               BorderBrush="#555"
                                               Margin="0,0,0,10"/>

                                            <TextBlock Text="Body Slots:" Foreground="Gray" Margin="0,0,0,5"/>

                                            <ItemsControl ItemsSource="{Binding SlotOptions}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>

                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="4"
                                                            Padding="5"
                                                            Margin="3"
                                                            Background="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}">

                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding ToggleSelectedCommand}" />
                                                            </Border.InputBindings>

                                                            <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="White"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </StackPanel>

                                        <!-- WEAPON -->
                                        <StackPanel Visibility="{Binding IsWeapon, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Damage:" Foreground="Gray" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Damage}"
                                               Background="#444"
                                               Foreground="White"
                                               BorderBrush="#555"
                                               Margin="0,0,0,10"/>

                                            <TextBlock Text="Speed:" Foreground="Gray" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Speed}"
                                               Background="#444"
                                               Foreground="White"
                                               BorderBrush="#555"
                                               Margin="0,0,0,10"/>

                                            <TextBlock Text="Reach:" Foreground="Gray" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Reach}"
                                               Background="#444"
                                               Foreground="White"
                                               BorderBrush="#555"
                                               Margin="0,0,0,10"/>

                                            <TextBlock Text="Stagger:" Foreground="Gray" Margin="0,0,0,5"/>
                                            <TextBox Text="{Binding Stagger}"
                                               Background="#444"
                                               Foreground="White"
                                               BorderBrush="#555"/>
                                        </StackPanel>

                                    </StackPanel>
                                </GroupBox>


                                <!-- Keywords -->
                                <!-- Top View -->
                                <StackPanel Grid.Row="3">
                                    <DockPanel Margin="0,5">
                                        <CheckBox Content="All Keywords (Expert)"
                                            IsChecked="{Binding ShowAllKeywords}"
                                            Foreground="White"
                                            DockPanel.Dock="Right"
                                            VerticalAlignment="Center"
                                            Margin="10,0" />
                                        <TextBlock Text="Search:"
                                             Foreground="White"
                                             VerticalAlignment="Center"
                                             Margin="0,0,5,0" />
                                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                           Background="#333"
                                           Foreground="White" />
                                    </DockPanel>

                                    <GroupBox Header="Selected Keywords"
                                        Foreground="White"
                                        Margin="0,0,0,10"
                                        Padding="10">

                                        <ItemsControl ItemsSource="{Binding SelectedKeywordsView}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="4"
                                                        Padding="5"
                                                        Margin="3"
                                                        Background="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}">

                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                Command="{Binding ToggleSelectedCommand}" />
                                                        </Border.InputBindings>

                                                        <TextBlock Text="{Binding Name}"
                                                            Foreground="White"
                                                            TextTrimming="CharacterEllipsis"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </GroupBox>
                                    <!-- Bottom View -->

                                    <GroupBox Header="Keywords"
                                        Foreground="White"
                                        Margin="0,0,0,15"
                                        Padding="10">

                                        <ItemsControl ItemsSource="{Binding FilteredKeywordsView}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"
                                                        ItemWidth="{Binding DataContext.KeywordItemWidth,
                                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        ItemHeight="{Binding DataContext.KeywordItemHeight,
                                                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="4"
                                                        Padding="5"
                                                        Margin="3"
                                                        ToolTip="{Binding Key}"
                                                        Background="{Binding IsSelected, Converter={StaticResource BoolToBrushConverter}}">

                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                Command="{Binding ToggleSelectedCommand}" />
                                                        </Border.InputBindings>

                                                        <TextBlock Text="{Binding Name}"
                                                            FontSize="{Binding DataContext.KeywordFontSize,
                                                                               RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            Foreground="White"
                                                            HorizontalAlignment="Center"
                                                            TextTrimming="CharacterEllipsis"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </GroupBox>



                                </StackPanel>


                                <!-- Materials / Recipe -->
                                <GroupBox Grid.Row="4"
                                                Foreground="White"
                                                Padding="10">
                                    <GroupBox.Header>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="Materials / Recipe"
                                                Foreground="White"
                                                DockPanel.Dock="Left" />
                                            <Button Content="+"
                                                Command="{Binding AddIngredientCommand}"
                                                Width="25"
                                                Height="25"
                                                Margin="10,0,0,0"
                                                DockPanel.Dock="Right"
                                                Background="#444"
                                                Foreground="White"
                                                BorderBrush="#666"
                                                FontWeight="Bold" />
                                        </DockPanel>
                                    </GroupBox.Header>

                                    <ItemsControl ItemsSource="{Binding CraftingIngredients}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="60" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <ComboBox Grid.Column="0"
                                                          ItemsSource="{Binding LocalMaterialsView}"
                                                          SelectedItem="{Binding SelectedMaterial}"
                                                          Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                          ToolTip="{Binding Key}"
                                                          DisplayMemberPath="Name"
                                                          IsEditable="True"
                                                          IsTextSearchEnabled="False"
                                                          StaysOpenOnEdit="True"
                                                          Background="#444"
                                                          Foreground="Black"
                                                          Margin="0,0,5,0" />

                                                    <TextBox Grid.Column="1"
                                                         Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="#444"
                                                         Foreground="White"
                                                         TextAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Padding="2" />

                                                    <Button Grid.Column="2"
                                                        Content="X"
                                                        Command="{Binding DataContext.RemoveIngredientCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent"
                                                        Foreground="Red"
                                                        FontWeight="Bold"
                                                        BorderThickness="0"
                                                        Margin="5,0,0,0" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </GroupBox>

                                <!-- Temper Recipe -->
                                <GroupBox Grid.Row="5"
                                    Foreground="White"
                                    Margin="0,15,0,0"
                                    Padding="10">
                                    <GroupBox.Header>
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="Temper Recipe"
                                                Foreground="White"
                                                DockPanel.Dock="Left" />
                                            <Button Content="+"
                                                Command="{Binding AddTemperIngredientCommand}"
                                                Width="25"
                                                Height="25"
                                                Margin="10,0,0,0"
                                                DockPanel.Dock="Right"
                                                Background="#444"
                                                Foreground="White"
                                                BorderBrush="#666"
                                                FontWeight="Bold" />
                                        </DockPanel>
                                    </GroupBox.Header>

                                    <StackPanel>
                                        <ItemsControl ItemsSource="{Binding TemperIngredients}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="60" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <ComboBox Grid.Column="0"
                                                            ItemsSource="{Binding LocalMaterialsView}"
                                                            SelectedItem="{Binding SelectedMaterial}"
                                                            DisplayMemberPath="Name"
                                                            Background="#444"
                                                            Foreground="Black"
                                                            Margin="0,0,5,0" />

                                                        <TextBox Grid.Column="1"
                                                           Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}"
                                                           Background="#444"
                                                           Foreground="White"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Padding="2" />

                                                        <Button Grid.Column="2"
                                                            Content="X"
                                                            Command="{Binding DataContext.RemoveTemperIngredientCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            Foreground="Red"
                                                            FontWeight="Bold"
                                                            BorderThickness="0"
                                                            Margin="5,0,0,0" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <TextBlock Text="{Binding TemperEditorID}"
                                               Foreground="Gray"
                                               Margin="0,10,0,0" />
                                    </StackPanel>
                                </GroupBox>

                            </Grid>
                        </ScrollViewer>
                    </DataTemplate>


                    <!-- PLUGIN-DETAIL -->
                    <DataTemplate DataType="{x:Type local:PluginNodeVM}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="20">
                                <TextBlock Text="{Binding PluginName}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="#FFD700"
                                           Margin="0,0,0,20" />

                                <GroupBox Header="Auto-Apply Settings (Auf alle Items der Mod anwenden)"
                                          Foreground="White"
                                          Margin="0,0,0,15"
                                          Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="Standard Material:"
                                                   Foreground="Gray"
                                                   VerticalAlignment="Center"
                                                   Margin="5" />
                                        <ComboBox Grid.Column="1"
                                                  Margin="5"
                                                  Background="#444"
                                                  Foreground="Black" />
                                        <CheckBox Grid.Column="2"
                                                  Content="Anwenden"
                                                  IsChecked="{Binding ApplyMaterial}"
                                                  Foreground="White"
                                                  VerticalAlignment="Center"
                                                  Margin="5" />
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Händler-Verteilung (Massen-Zuweisung)"
                                          Foreground="White"
                                          Margin="0,0,0,15"
                                          Padding="10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Content="Add all items to Vendors"
                                                    Padding="10,5"
                                                    Margin="5"
                                                    Background="#444"
                                                    Foreground="White" />
                                        </Grid>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </DataTemplate>

                </ContentPresenter.Resources>
            </ContentPresenter>
        </Grid>
    </DockPanel>
</UserControl>
